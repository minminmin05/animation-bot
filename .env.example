# ========================================
# SCHOOL MANAGEMENT APP - ENVIRONMENT CONFIGURATION
# ========================================
# Copy this file to .env and fill in your actual values
# NEVER commit .env file to version control

# ========================================
# SUPABASE CONFIGURATION (REQUIRED)
# ========================================
# Get these from your Supabase project settings:
# 1. Go to https://supabase.com
# 2. Create a new project or select existing
# 3. Go to Project Settings > API
# 4. Copy the Project URL and anon/public key

VITE_SUPABASE_URL=YOUR_SUPABASE_URL_HERE
VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY_HERE

# ========================================
# API CONFIGURATION (OPTIONAL)
# ========================================
# If using a custom backend API instead of Supabase

VITE_API_BASE_URL=http://localhost:3000/api
VITE_API_TIMEOUT=30000

# ========================================
# FEATURE FLAGS
# ========================================
# Enable/disable features without code changes

VITE_ENABLE_ATTENDANCE=true
VITE_ENABLE_GRADING=true
VITE_ENABLE_SCHEDULING=true
VITE_ENABLE_ANNOUNCEMENTS=true
VITE_ENABLE_PARENT_PORTAL=true
VITE_ENABLE_SMS_NOTIFICATIONS=false
VITE_ENABLE_PAYMENT_COLLECTION=false

# ========================================
# SCHOOL CONFIGURATION
# ========================================
# Default school settings (can be overridden in database)

VITE_SCHOOL_NAME=My School
VITE_SCHOOL_DOMAIN=myschool.edu
VITE_ACADEMIC_YEAR_START_MONTH=8

# ========================================
# EXTERNAL SERVICES (OPTIONAL)
# ========================================
# Add credentials for external services as needed

# Email Service (SendGrid, Mailgun, etc.)
VITE_EMAIL_SERVICE_API_KEY=YOUR_EMAIL_API_KEY_HERE
VITE_EMAIL_FROM=noreply@school.edu

# SMS Service (Twilio, etc.)
VITE_SMS_SERVICE_API_KEY=YOUR_SMS_API_KEY_HERE
VITE_SMS_FROM_NUMBER=YOUR_PHONE_NUMBER_HERE

# Payment Gateway (Stripe, etc.)
VITE_PAYMENT_PUBLIC_KEY=YOUR_PAYMENT_PUBLIC_KEY_HERE

# Storage Service (AWS S3, Cloudinary, etc.)
VITE_STORAGE_BUCKET_NAME=YOUR_BUCKET_NAME_HERE
VITE_STORAGE_REGION=YOUR_STORAGE_REGION_HERE

# Push Notifications (Firebase, etc.)
VITE_FCM_API_KEY=YOUR_FCM_API_KEY_HERE
VITE_FCM_PROJECT_ID=YOUR_PROJECT_ID_HERE

# ========================================
# DEVELOPMENT/PRODUCTION SETTINGS
# ========================================
# Environment mode
NODE_ENV=development

# Enable debug mode for development
VITE_DEBUG=true

# API request logging
VITE_LOG_API_REQUESTS=true
